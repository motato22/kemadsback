APP_NAME="KEM Advertising"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de datos ────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kem_advertising
DB_USERNAME=root
DB_PASSWORD=

# ─── Redis (colas, caché, sesiones) ──────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# Configurar en config/filesystems.php > disks > r2
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_DEFAULT_REGION=auto
CLOUDFLARE_R2_BUCKET=kem-advertising
CLOUDFLARE_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CLOUDFLARE_R2_URL=

# ─── Email transaccional (Resend recomendado) ─────────────────────────────────
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@kemadvertising.com"
MAIL_FROM_NAME="KEM Advertising"
RESEND_API_KEY=

# ─── Sistema de Publicidad ────────────────────────────────────────────────────
# URL que usan las tablets y el comando ADB (Ngrok, dominio real o IP:puerto). Si no se define, se usa APP_URL.
ADV_PUBLIC_APP_URL=https://tu-dominio.ngrok-free.app
ADV_OFFLINE_THRESHOLD_MINUTES=10
ADV_BATTERY_ALERT_THRESHOLD=20
ADV_ALERT_EMAIL=admin@kemadvertising.com
ADV_PROVISION_QR_TTL_HOURS=24
ADV_SIGNED_URL_TTL_MINUTES=2880

# Versión actual de la App Reproductora (actualizar al hacer release OTA)
ADV_LATEST_APK_VERSION=
ADV_LATEST_APK_URL=
ADV_LATEST_APK_SHA256=

# ─── Laravel Horizon ─────────────────────────────────────────────────────────
HORIZON_ENABLED=true

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,adv-panel.kemadvertising.com
