APP_NAME="KEM Advertising (Local)"
APP_ENV=local
APP_KEY=base64:0HdCTwZLcKr6yN7EOFm7mwEkkkohfKPscH02Hyww+yI=
APP_DEBUG=true
APP_URL=https://morris-cliquy-umbilically.ngrok-free.dev

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Base de datos (Docker local) ────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=kem_advertising
DB_USERNAME=kem_user
DB_PASSWORD=kem_secret

# ─── Redis (Docker local) ────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── Storage local en desarrollo (Minio o R2 real) ───────────────────────────
# 🔥 CAMBIO CRÍTICO 1: No uses localhost aquí. Pon la IP local de tu Mac (ej. 192.168.1.75).
# Si dejas localhost, la tablet buscará los videos dentro de sí misma y no en tu Mac.
CLOUDFLARE_R2_ACCESS_KEY_ID=minio
CLOUDFLARE_R2_SECRET_ACCESS_KEY=minio123
CLOUDFLARE_R2_DEFAULT_REGION=us-east-1
CLOUDFLARE_R2_BUCKET=kem-advertising-local
CLOUDFLARE_R2_ENDPOINT=http://192.168.1.84:9000
CLOUDFLARE_R2_URL=http://192.168.1.84:9000/kem-advertising-local

# ─── Email (Mailtrap en desarrollo) ──────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="dev@kemadvertising.local"
MAIL_FROM_NAME="KEM Dev"

# ─── Sistema de Publicidad ────────────────────────────────────────────────────
ADV_OFFLINE_THRESHOLD_MINUTES=10
ADV_BATTERY_ALERT_THRESHOLD=20
ADV_ALERT_EMAIL=dev@kemadvertising.local
ADV_PROVISION_QR_TTL_HOURS=24

# App Reproductora — OTA
# Versión, URL y SHA-256 se gestionan desde el panel: Dispositivos > APK Reproductora (OTA)
# No es necesario definir estas variables; el HeartbeatController lee player-info.json
ADV_LATEST_APK_VERSION=
ADV_LATEST_APK_URL=
ADV_LATEST_APK_SHA256=

# App Guardiana
ADV_GUARDIAN_APK_URL=https://morris-cliquy-umbilically.ngrok-free.dev/api/adv/apk/guardian
ADV_GUARDIAN_APK_SHA256=NZxuParBhPIa8Hro8FgwdGMD9fl4FKCrxkvuNa0sd2A
ADVERTISING_GUARDIAN_CERT_CHECKSUM=NZxuParBhPIa8Hro8FgwdGMD9fl4FKCrxkvuNa0sd2A
# 🔥 CAMBIO CRÍTICO 3: Por el código Kotlin que me mostraste antes, tu app se llama "guardiana" y tu clase "GuardianaAdminReceiver". 
# Esto debe coincidir EXACTAMENTE con tu AndroidManifest.xml o la instalación fallará.
ADV_GUARDIAN_COMPONENT_NAME=com.kemadvertising.guardiana.debug/com.kemadvertising.guardiana.data.receiver.GuardianaAdminReceiver

# ─── Livewire (límite subida temporal para FileUpload; valor en KB) ───────────
LIVEWIRE_TEMPORARY_FILE_UPLOAD_MAX_SIZE=102400

# ─── Horizon ─────────────────────────────────────────────────────────────────
HORIZON_ENABLED=true
